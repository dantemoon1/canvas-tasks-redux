{
  "manifest_version": 2,
  "name": "Tasks for Canvas Redux",
  "description": "A better to-do list sidebar for Canvas.",
  "version": "2.0.0",
  "icons": {
    "128": "icon-128.png"
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icon-128.png"
    }
  },
  "permissions": ["storage", "activeTab"],
  "optional_permissions": ["https://*/*"],
  "background": {
    "scripts": ["background.bundle.js"]
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true,
    "browser_style": true,
    "chrome_style": false
  },
  "content_security_policy": "script-src 'self'; object-src 'self'",
  "browser_specific_settings": {
    "gecko": {
      "id": "tasks-for-canvas@open-source"
    }
  }
}
